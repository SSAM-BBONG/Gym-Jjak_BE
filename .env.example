# AWS S3 설정
# IAM 계정에서 발급받은 Access Key 입력
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET_NAME=

# docker 관련 설정
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
MYSQL_PORT=3307

BACKEND_PORT=

SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=1209600000

APP_SCHEDULER_RETENTION_CRON=0 0 3 * * *
APP_SCHEDULER_RETENTION_ZONE=Asia/Seoul
APP_RETENTION_REPORT_GROUP_PERIOD_DAYS=180
APP_RETENTION_REPORT_GROUP_BATCH_SIZE=500

CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET_KEY=
