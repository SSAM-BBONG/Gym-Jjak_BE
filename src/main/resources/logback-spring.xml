<?xml version="1.0" encoding="UTF-8"?>

<!--
    ============================================================
    Gym-Jjak logback-spring.xml
    ============================================================

    이 파일의 역할
    - Spring Boot 애플리케이션의 로그 출력 정책을 정의한다.
    - 로그를 콘솔/파일/에러 파일/성능 파일로 분리할 수 있다.
    - dev, prod, test 환경별로 다른 로그 전략을 적용할 수 있다.

    로그 처리 흐름
    Logger -> Appender -> Encoder -> 실제 출력 대상

    1. Logger
       - 어떤 패키지/클래스의 로그를 어떤 레벨로 남길지 결정한다.

    2. Appender
       - 로그를 어디로 보낼지 결정한다.
       - 예: 콘솔, 일반 파일, 에러 전용 파일, 성능 로그 파일

    3. Encoder
       - 로그를 어떤 형식의 문자열로 출력할지 결정한다.

    4. RollingPolicy
       - 로그 파일이 너무 커지지 않도록 날짜/크기 기준으로 분리하고 보관 기간을 관리한다.

    주요 MDC 값
    - traceId    : 요청 추적용 고유 식별자
    - method     : HTTP Method (GET, POST 등)
    - requestURI : 요청 URI
    - remoteAddr : 요청 클라이언트 IP
    - userAgent  : 요청을 보낸 클라이언트/브라우저 정보
-->
<configuration>

    <property name="LOG_PATH" value="./logs"/>
    <property name="LOG_FILE_NAME" value="gym-jjak"/>
<!--    콘솔 로그 패턴-->
    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan([%X{traceId:-}]) %yellow(%logger{36}) - %msg%n"/>
<!--    파일 로그 패턴-->
    <property name="FILE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId:-}] [%X{method:-}] [%X{requestURI:-}] [%X{remoteAddr:-}] %logger{36} - %msg%n"/>
<!--    로그를 터미널에 출력-->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
<!--    전체 로그를 일반 파일에 저장한다.-->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}.log</file>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <!--
            날짜/크기 기준 파일 분리 정책

            fileNamePattern : 분리된 로그 파일 이름 규칙
            maxFileSize     : 파일 하나의 최대 크기
            maxHistory      : 로그 보관 일수
            totalSizeCap    : 전체 로그 파일 총 용량 제한
        -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>
<!--    에러 파일 저장 양식-->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}-error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
    </appender>
<!--    성능 측정 로그 저장 양식-->
    <appender name="PERFORMANCE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}-performance.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{traceId:-}] %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}-performance.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>
<!--    개발 환경 전략-->
    <springProfile name="local,dev,default,docker">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>

        <logger name="com.ssambbong.gymjjak" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>

        <logger name="com.ssambbong.gymjjak.global.infrastructure.aop.PerformanceLogAspect"
                level="INFO"
                additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="PERFORMANCE_FILE"/>
        </logger>

        <logger name="org.springframework" level="INFO"/>
        <logger name="org.springframework.web" level="DEBUG"/>
        <logger name="org.springframework.transaction" level="DEBUG"/>
        <logger name="org.hibernate" level="INFO"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <logger name="com.zaxxer.hikari" level="INFO"/>
    </springProfile>
<!--    운영 환경 전략 외부는 warn, 프로젝트 로그는 info, 에러는 별도 파일 저장-->
    <springProfile name="prod">
        <root level="WARN">
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>

        <logger name="com.ssambbong.gymjjak" level="INFO" additivity="false">
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>

        <logger name="com.ssambbong.gymjjak.global.infrastructure.aop.PerformanceLogAspect"
                level="INFO"
                additivity="false">
            <appender-ref ref="PERFORMANCE_FILE"/>
        </logger>

        <logger name="org.springframework" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>
        <logger name="com.zaxxer.hikari" level="WARN"/>
    </springProfile>
<!--    테스트 환경 전략-->
    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.ssambbong.gymjjak" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <logger name="org.springframework.test" level="WARN"/>
        <logger name="org.springframework.boot.test" level="WARN"/>
    </springProfile>

</configuration>
